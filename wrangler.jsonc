{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "greendays",
  "main": "worker/index.js",
  "compatibility_date": "2026-07-01",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    // The Worker must see every request first: it 301-redirects the retired
    // lab.ryantnance.com/greendays* host to greendays.day and handles the API
    // routes; everything else on greendays.day falls through to static assets.
    "run_worker_first": true
  },
  "routes": [
    {
      // Custom Domain (whole-hostname, no path pattern): Cloudflare creates the
      // DNS record + certificate for greendays.day automatically on deploy —
      // the zone currently has zero DNS records, so this (not a wildcard
      // zone route) is required for the domain to resolve at all.
      "pattern": "greendays.day",
      "custom_domain": true
    },
    {
      // Retired path — kept only so the Worker can 301 old links/bookmarks
      // to greendays.day instead of 404ing.
      "pattern": "lab.ryantnance.com/greendays*",
      "zone_name": "ryantnance.com"
    }
  ],
  "vars": {
    // Sonnet 5 carries the recipe voice; switch to claude-haiku-4-5 later as
    // the cost fallback after A/B-ing the voice (PRE_HANDOFF_DECISIONS.md).
    "RECIPE_MODEL": "claude-sonnet-5"
  },
  // Privacy-first product analytics: aggregate-only, no user IDs, no PII.
  // `binding` is the env var the Worker reads (env.GD_EVENTS); `dataset` is the
  // queryable table name (SELECT ... FROM Green_Days_Early_Days).
  "analytics_engine_datasets": [
    { "binding": "GD_EVENTS", "dataset": "Green_Days_Early_Days" }
  ],
  // Light per-IP rate limit on the recipe endpoint (cost control).
  "unsafe": {
    "bindings": [
      {
        "name": "RECIPE_RL",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": { "limit": 8, "period": 60 }
      }
    ]
  }
  // Secrets (wrangler secret put, never committed):
  //   ANTHROPIC_API_KEY — recipe engine
}
