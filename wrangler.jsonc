{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "greendays",
  "main": "worker/index.js",
  "compatibility_date": "2026-07-01",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    // Only API calls invoke the Worker; everything else is served straight
    // from static assets (SPA has no client-side routes beyond /greendays/).
    "run_worker_first": ["/greendays/api/*"]
  },
  "routes": [
    {
      "pattern": "lab.ryantnance.com/greendays*",
      "zone_name": "ryantnance.com"
    }
  ],
  "vars": {
    // Sonnet 5 carries the recipe voice; switch to claude-haiku-4-5 later as
    // the cost fallback after A/B-ing the voice (PRE_HANDOFF_DECISIONS.md).
    "RECIPE_MODEL": "claude-sonnet-5"
  },
  // Privacy-first product analytics: aggregate-only, no user IDs, no PII.
  // `binding` is the env var the Worker reads (env.GD_EVENTS); `dataset` is the
  // queryable table name (SELECT ... FROM Green_Days_Early_Days).
  "analytics_engine_datasets": [
    { "binding": "GD_EVENTS", "dataset": "Green_Days_Early_Days" }
  ],
  // Light per-IP rate limit on the recipe endpoint (cost control).
  "unsafe": {
    "bindings": [
      {
        "name": "RECIPE_RL",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": { "limit": 8, "period": 60 }
      }
    ]
  }
  // Secrets (wrangler secret put, never committed):
  //   ANTHROPIC_API_KEY — recipe engine
}
